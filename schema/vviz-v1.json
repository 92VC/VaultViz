{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vaultviz.fr/schema/v1.json",
  "title": "VaultViz document (.vviz) v1",
  "description": "Schéma de validation des fichiers .vviz consommés par VaultViz V0. Décision §16 Q7 (B-033b) : spec = DSL VaultViz prétraité, pas vgplot JSON brut.",
  "type": "object",
  "required": ["vviz", "data", "spec"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "URL canonique du schéma. Informative — non vérifiée."
    },
    "vviz": {
      "type": "object",
      "required": ["version", "title"],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "const": "1.0"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "description": {
          "type": "string",
          "maxLength": 2000
        },
        "author": {
          "type": "string",
          "maxLength": 200
        },
        "created": {
          "type": "string",
          "format": "date"
        },
        "updated": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "data": {
      "type": "object",
      "required": ["sources"],
      "additionalProperties": false,
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "type": "object",
            "required": ["name", "path"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-zA-Z_][a-zA-Z0-9_]{0,63}$",
                "description": "Alias logique (identifiant SQL)."
              },
              "path": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1024,
                "description": "Chemin du Parquet. Acceptés : UNC posix (//host/share/...), relatif (./...), lettre de lecteur Windows (Z:/...). Cf. ADR-007.",
                "not": {
                  "anyOf": [
                    { "pattern": "^https?://" },
                    { "pattern": "^ftp://" },
                    { "pattern": "^file://" },
                    { "pattern": "^data:" },
                    { "pattern": "^javascript:" }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "spec": {
      "type": "object",
      "description": "Spec de visualisation (DSL VaultViz, cf. §16 Q7).",
      "required": ["engine", "views"],
      "additionalProperties": false,
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["mosaic"],
          "description": "Moteur de rendu. V0 : mosaic uniquement. Repli vega-lite suivra (R-8)."
        },
        "layout": {
          "type": "string",
          "enum": ["vstack", "hstack", "grid", "dashboard"],
          "default": "vstack",
          "description": "Disposition macro des vues. `dashboard` : placement par zones via view.options.region (kpi/main/side/full)."
        },
        "gridRatio": {
          "type": "array",
          "description": "Layout `dashboard` : ratio des colonnes [principale, latérale]. Défaut [1.32, 1]. Réduire la principale (ex. carte) au profit des vues de droite.",
          "items": { "type": "number", "exclusiveMinimum": 0 },
          "minItems": 2,
          "maxItems": 2
        },
        "selections": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "object",
            "required": ["id", "kind"],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-zA-Z_][a-zA-Z0-9_]{0,63}$"
              },
              "kind": {
                "type": "string",
                "enum": ["single", "interval", "crossfilter"]
              }
            }
          }
        },
        "tabs": {
          "type": "array",
          "description": "Onglets internes du dashboard. Chaque vue est rattachée via `options.tab` ; une carte KPI peut pointer vers un onglet via `options.navigateTo`. Absent → page unique.",
          "maxItems": 16,
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-zA-Z_][a-zA-Z0-9_]{0,63}$"
              },
              "label": { "type": "string" }
            }
          }
        },
        "views": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": {
            "type": "object",
            "required": ["id", "type", "source"],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-zA-Z_][a-zA-Z0-9_]{0,63}$"
              },
              "title": {
                "type": "string",
                "maxLength": 200
              },
              "type": {
                "type": "string",
                "enum": [
                  "map_choropleth",
                  "bar",
                  "barX",
                  "barY",
                  "line",
                  "area",
                  "dot",
                  "table",
                  "kpi"
                ]
              },
              "source": {
                "type": "string",
                "pattern": "^[a-zA-Z_][a-zA-Z0-9_]{0,63}$",
                "description": "Référence à `data.sources[].name`."
              },
              "encoding": {
                "type": "object",
                "description": "Mapping champ → canal visuel (x, y, color, size, geo, …). Validé sémantiquement à l'exécution.",
                "additionalProperties": true
              },
              "filterBy": {
                "type": "string",
                "description": "Réfère un `spec.selections[].id`."
              },
              "options": {
                "type": "object",
                "description": "Options de rendu (largeur, hauteur, palette, …).",
                "additionalProperties": true
              }
            }
          }
        }
      }
    }
  }
}
