{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vaultviz.fr/schema/v1.json",
  "title": "VaultViz document (.vviz) v1 — draft B-033a",
  "description": "Schéma de validation des fichiers .vviz consommés par VaultViz V0. Resserrage de la clé `spec` en B-033b.",
  "type": "object",
  "required": ["vviz", "data", "spec"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "URL canonique du schéma. Informative — non vérifiée."
    },
    "vviz": {
      "type": "object",
      "required": ["version", "title"],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "const": "1.0",
          "description": "Version du format .vviz. V0 = 1.0 strict."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "description": {
          "type": "string",
          "maxLength": 2000
        },
        "author": {
          "type": "string",
          "maxLength": 200
        },
        "created": {
          "type": "string",
          "format": "date"
        },
        "updated": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "data": {
      "type": "object",
      "required": ["sources"],
      "additionalProperties": false,
      "properties": {
        "sources": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "type": "object",
            "required": ["name", "path"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-zA-Z_][a-zA-Z0-9_]{0,63}$",
                "description": "Alias logique (identifiant SQL) — pas d'espaces, pas de caractères spéciaux."
              },
              "path": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1024,
                "description": "Chemin du Parquet. Acceptés : UNC posix (//host/share/...), relatif (./...), lettre de lecteur Windows (Z:/...). Cf. ADR-007.",
                "not": {
                  "anyOf": [
                    { "pattern": "^https?://" },
                    { "pattern": "^ftp://" },
                    { "pattern": "^file://" },
                    { "pattern": "^data:" },
                    { "pattern": "^javascript:" }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "spec": {
      "type": "object",
      "description": "Spec de visualisation (B-033b : DSL VaultViz). En draft B-033a on autorise tout objet ouvert.",
      "minProperties": 1
    }
  }
}
