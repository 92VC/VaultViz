{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "main-capability",
  "description": "Capability principale VaultViz : lecture FS read-only sur partage SMB/UNC + chemins locaux dev/déconnecté + lecteurs mappés. Voir docs/adr/ADR-007-unc-paths.md et docs/adr/ADR-008-no-network.md (aucun accès réseau, aucun appel sortant).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "fs:default",
    "dialog:default",
    "dialog:allow-open",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$APPLOCALDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$APPLOCALDATA/**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$APPLOCALDATA/**" }
      ]
    }
  ]
}
